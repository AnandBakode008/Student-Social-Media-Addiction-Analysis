          <Textbox Name="Textbox91">
            <rd:DefaultName>Textbox91</rd:DefaultName>
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>67% of students report that social media negatively affects their academic performance. </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Snapchat (921) and Instagram (901) are the most used platforms, together accounting for 36.4% of usage.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>High School students show the highest average addiction score (5.64) compared to Graduates (5.44). </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Females average slightly higher daily usage (6.60 hrs) compared to Males (6.46 hrs). </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Instagram is the #1 source of conflict among students, followed by Twitter and WhatsApp.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Students average only 6.04 hrs of sleep per night — below the recommended 8 hours.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Mental health scores and addiction scores are closely correlated across all platforms.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Mexico has the highest average addiction score among all countries surveyed</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#333333</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <ListStyle>Bulleted</ListStyle>
                <ListLevel>1</ListLevel>
                <SpaceAfter>2mm</SpaceAfter>
                <Style />
              </Paragraph>
            </Paragraphs>
